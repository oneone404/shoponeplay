generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model CategoryGroup {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  categories Category[]
}

model Category {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  image         String?
  groupId       String
  startingPrice Float?
  totalSold     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  group         CategoryGroup @relation(fields: [groupId], references: [id])
  products      Product[]
}

model Product {
  id          String          @id @default(cuid())
  price       Float
  oldPrice    Float?
  type        ProductType     @default(PLAY)
  images      String[]
  thumbnail   String?
  description String[]
  categoryId  String
  stats       Json?
  sold        Boolean         @default(false)
  isHidden    Boolean         @default(false)
  stock       Int             @default(1)
  uploaderId  String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  secrets     AccountSecret[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  category    Category        @relation(fields: [categoryId], references: [id])
  uploader    User            @relation("ProductUploader", fields: [uploaderId], references: [id])

  @@index([uploaderId])
  @@index([categoryId])
}

model User {
  id                   String               @id @default(cuid())
  name                 String?
  email                String?              @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  role                 Role                 @default(USER)
  balance              Float                @default(0)
  totalDeposited       Float                @default(0)
  twoFactorEnabled     Boolean              @default(false)
  twoFactorSecret      String?
  sellerBankName       String?
  sellerAccountNumber  String?
  sellerAccountName    String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  lastIP               String?
  accountId            String?
  savedAccountIds      Json                 @default("[]")
  accounts             Account[]
  accountExportBatches AccountExportBatch[]
  uploadedSecrets      AccountSecret[]      @relation("SecretUploader")
  bankDeposits         BankDeposit[]        @relation("UserBankDeposits")
  cardDeposits         CardDeposit[]        @relation("UserCardDeposits")
  cartItems            CartItem[]
  hackOrders           HackOrder[]
  orders               Order[]
  posts                Post[]
  uploadedProducts     Product[]            @relation("ProductUploader")
  serviceOrders        ServiceOrder[]
  sessions             Session[]
  topupOrders          TopupOrder[]
  transactions         Transaction[]        @relation("UserTransactions")
  activities           UserActivity[]
  withdrawals          Withdrawal[]
  giftcodeHistories    GiftcodeHistory[]
  config               UserConfig?
}

model GameService {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  thumbnail   String
  description String?
  type        ServiceType     @default(LEVELING)
  status      ServiceStatus   @default(ACTIVE)
  fields      Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  options     ServiceOption[]
  orders      ServiceOrder[]
}

model ServiceOption {
  id          String         @id @default(cuid())
  serviceId   String
  name        String
  price       Float
  thumbnail   String?
  description String?
  status      ServiceStatus  @default(ACTIVE)
  service     GameService    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  orders      ServiceOrder[]
}

model ServiceOrder {
  id           String             @id @default(cuid())
  serviceId    String
  optionId     String
  userId       String
  customerData Json
  totalAmount  Float
  status       ServiceOrderStatus @default(PENDING)
  adminNote    Json               @default("[]")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  option       ServiceOption      @relation(fields: [optionId], references: [id])
  service      GameService        @relation(fields: [serviceId], references: [id])
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Transaction {
  id            String          @id @default(cuid())
  userId        String
  amount        Float
  balanceBefore Float           @default(0)
  balanceAfter  Float           @default(0)
  type          TransactionType
  description   String?
  orderId       String?
  bankDepositId String?
  cardDepositId String?
  adminId       String?
  createdAt     DateTime        @default(now())
  user          User            @relation("UserTransactions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model BankDeposit {
  id            String        @id @default(cuid())
  userId        String
  amount        Float
  bankName      String
  transactionId String?       @unique
  description   String?
  status        DepositStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation("UserBankDeposits", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model CardDeposit {
  id            String        @id @default(cuid())
  userId        String
  cardType      String
  serial        String
  pin           String
  declaredValue Float
  realValue     Float?
  amount        Float?
  requestId     String        @unique
  status        DepositStatus @default(PENDING)
  note          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation("UserCardDeposits", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EmailVerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, code])
}

model BankInfo {
  id            String   @id @default(cuid())
  bankName      String
  accountNumber String
  accountName   String
  logo          String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  selected  Boolean  @default(true)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model AccountSecret {
  id            String               @id @default(cuid())
  productId     String
  username      String
  password      String
  extraInfo     String?
  isSold        Boolean              @default(false)
  soldAt        DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  orderItemId   String?
  accountId     String?
  exportBatchId String?
  exportFormat  AccountExportFormat?
  exportedAt    DateTime?
  exportedById  String?
  uploaderId    String?
  status        AccountSecretStatus  @default(AVAILABLE)
  exportBatch   AccountExportBatch?  @relation(fields: [exportBatchId], references: [id])
  orderItem     OrderItem?           @relation(fields: [orderItemId], references: [id])
  product       Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  uploader      User?                @relation("SecretUploader", fields: [uploaderId], references: [id])

  @@index([productId])
  @@index([accountId])
  @@index([status])
  @@index([exportBatchId])
}

model AccountExportBatch {
  id           String              @id @default(cuid())
  productId    String?
  exportedById String
  format       AccountExportFormat
  action       AccountExportAction @default(EXPORT_ONLY)
  quantity     Int
  fileName     String?
  createdAt    DateTime            @default(now())
  exportedBy   User                @relation(fields: [exportedById], references: [id])
  secrets      AccountSecret[]

  @@index([exportedById])
  @@index([productId])
  @@index([createdAt])
}

model Order {
  id          String        @id @default(cuid())
  userId      String
  totalAmount Float
  status      OrderStatus   @default(COMPLETED)
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       OrderItem[]
  profit      SystemProfit?
}

model OrderItem {
  id               String          @id @default(cuid())
  orderId          String
  productId        String?
  quantity         Int
  priceAtPurchase  Float
  titleSnapshot    String
  typeSnapshot     String
  deliveredSecrets AccountSecret[]
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product?        @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Post {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  excerpt   String?
  category  String   @default("news")
  image     String?
  featured  Boolean  @default(false)
  published Boolean  @default(false)
  views     Int      @default(0)
  readTime  String?
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id])

  @@index([authorId])
  @@index([slug])
}

model Config {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VisitorLog {
  id        String   @id @default(cuid())
  ip        String
  userAgent String?
  path      String
  method    String
  createdAt DateTime @default(now())

  @@index([ip])
  @@index([createdAt])
}

model BannedIP {
  id        String    @id @default(cuid())
  ip        String    @unique
  reason    String
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([ip])
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  type      String
  ip        String?
  userAgent String?
  details   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Withdrawal {
  id            String         @id @default(cuid())
  userId        String
  amount        Float
  bankName      String
  accountNumber String
  accountName   String
  status        WithdrawStatus @default(PENDING)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SystemProfit {
  id        String   @id @default(cuid())
  amount    Float
  type      String   @default("ORDER_FEE")
  orderId   String?  @unique
  note      String?
  createdAt DateTime @default(now())
  order     Order?   @relation(fields: [orderId], references: [id])
}

model HackTool {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  version         String
  description     String?
  thumbnail       String?
  fileName        String?
  fileSize        String?
  features        Json?
  requirements    String?
  videoUrl        String?
  status          HackStatus       @default(ACTIVE)
  totalDownload   Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  prices          Json?
  externalId      Int?
  changelog       Json?
  downloadUrl     Json?
  freeKeySessions FreeKeySession[]
  orders          HackOrder[]
}

model FreeKeySession {
  id          String   @id @default(cuid())
  token       String   @unique
  hackId      String
  sessionCode String?
  visitorId   String?
  status      String   @default("PENDING")
  key         String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  hack        HackTool @relation(fields: [hackId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([visitorId])
}

model HackOrder {
  id         String   @id @default(cuid())
  userId     String
  hackId     String
  duration   String
  machines   Int      @default(1)
  totalPrice Float
  key        String?
  status     String   @default("COMPLETED")
  createdAt  DateTime @default(now())
  hack       HackTool @relation(fields: [hackId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([hackId])
}

model TopupProduct {
  id           String       @id @default(cuid())
  name         String
  vngProductId String?
  cardValue    Int
  serviceCode  String       @default("ZING")
  sellPrice    Int
  enabled      Boolean      @default(true)
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  orders       TopupOrder[]
}

model TopupOrder {
  id             String           @id @default(cuid())
  userId         String
  productId      String?
  roleId         String
  roleName       String
  serverId       String
  amount         Int
  cardValue      Int
  cardRequestId  String?
  cardOrderCode  String?
  cardSerial     String?
  cardPin        String?
  vngProductId   String?
  vngUserId      String?
  vngReturnCode  Int?
  status         TopupOrderStatus @default(PENDING)
  retryCount     Int              @default(0)
  maxRetries     Int              @default(5)
  errorMessage   String?
  statusLog      Json             @default("[]")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  completedAt    DateTime?
  productName    String?
  vngOrderNumber String?
  vngQrCode      String?
  vngQrExpiredAt DateTime?
  adminNote      Json             @default("[]")
  product        TopupProduct?    @relation(fields: [productId], references: [id])
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum ServiceType {
  LEVELING
  TOPUP
  OTHER
}

enum ServiceStatus {
  ACTIVE
  MAINTENANCE
  HIDDEN
}

enum ServiceOrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

enum TransactionType {
  DEPOSIT
  PURCHASE
  REFUND
  ADMIN_ADD
  ADMIN_SUB
  WITHDRAW
  SALE_REVENUE
}

enum DepositStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum ProductType {
  PLAY
  RANDOM
  SERVICE
}

enum Role {
  USER
  SELLER
  ADMIN
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum AccountSecretStatus {
  AVAILABLE
  SOLD
  EXPORTED
  DISABLED
}

enum AccountExportFormat {
  CSV
  TXT
  JSON
}

enum AccountExportAction {
  EXPORT_ONLY
  EXPORT_AND_DISABLE
}

enum WithdrawStatus {
  PENDING
  COMPLETED
  CANCELLED
  REJECTED
}

enum HackStatus {
  ACTIVE
  MAINTENANCE
  HIDDEN
}

enum TopupOrderStatus {
  PENDING
  BUYING_CARD
  WAITING_CARD
  CARD_READY
  PROCESSING_VNG
  COMPLETED
  ERROR
  REFUNDED
  WAITING_STOCK
  WAITING_ADMIN_PAY
}

model GiftcodeHistory {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  code      String
  status    String   // SUCCESS, FAILED
  message   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
}

model UserConfig {
  id           String   @id @default(cuid())
  userId       String   @unique
  autoGiftcode Boolean  @default(false)
  settings     Json     @default("{}") // Cho các cấu hình mở rộng sau này
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GlobalGiftcode {
  id        String   @id @default(cuid())
  code      String   @unique
  gameCode  String   @default("661")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}
